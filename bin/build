#!/bin/bash
rm -fr build/artifacts
mkdir build/artifacts
rm -fr build/zephyr/*
west build -s zmk/app -b nice_nano_v2 -- -DZMK_CONFIG=${PWD}/config -DSHIELD=corne_left
cp build/zephyr/zmk.uf2 "build/artifacts/corne_left-nice_nano_v2-zmk.uf2"
rm -fr build/zephyr/*
west build -s zmk/app -b nice_nano_v2 -- -DZMK_CONFIG=${PWD}/config -DSHIELD=corne_right
cp build/zephyr/zmk.uf2 "build/artifacts/corne_right-nice_nano_v2-zmk.uf2"

